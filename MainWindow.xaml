<Window x:Class="BarterPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Barter+" 
        Height="750" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="PrimaryBlue">#1E40AF</Color>
            <Color x:Key="AccentGreen">#059669</Color>
            <Color x:Key="AccentOrange">#EA580C</Color>
            <Color x:Key="LightGray">#F8FAFC</Color>
            <Color x:Key="BorderGray">#E2E8F0</Color>
            <Color x:Key="TextDark">#1E293B</Color>
            <Color x:Key="TextMuted">#64748B</Color>

            <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
            <SolidColorBrush x:Key="LightGrayBrush" Color="{StaticResource LightGray}"/>
            <SolidColorBrush x:Key="BorderGrayBrush" Color="{StaticResource BorderGray}"/>
            <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
            
            <!-- Effects -->
            <DropShadowEffect x:Key="ShadowEffect" BlurRadius="12" ShadowDepth="3" Opacity="0.08" Color="#000000"/>
            <DropShadowEffect x:Key="ShadowEffectLight" BlurRadius="8" ShadowDepth="2" Opacity="0.05" Color="#000000"/>

            <!-- Font Sizes -->
            <sys:Double x:Key="FontSize.Small">11</sys:Double>
            <sys:Double x:Key="FontSize.Normal">12</sys:Double>
            <sys:Double x:Key="FontSize.Medium">13</sys:Double>
            <sys:Double x:Key="FontSize.Large">15</sys:Double>
            <sys:Double x:Key="FontSize.XLarge">28</sys:Double>
            <sys:Double x:Key="FontSize.Title">32</sys:Double>

            <!-- Button Style -->
            <Style x:Key="FunctionButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="{StaticResource FontSize.Medium}"/>
                <Setter Property="FontWeight" Value="600"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="24,16" Effect="{StaticResource ShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0" 
                           Text="SALES" 
                           FontSize="{StaticResource FontSize.Title}" 
                           FontWeight="700" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <!-- Transaction & DateTime Info -->
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="24,0,24,0">
                    <TextBlock Text="Trans. ID: 42" Foreground="White" FontSize="{StaticResource FontSize.Small}" FontWeight="500"/>
                    <TextBlock Text="Terminal ID: 000C09" Foreground="White" FontSize="{StaticResource FontSize.Small}" FontWeight="500"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentDateTime}" 
                           Foreground="White" 
                           FontSize="{StaticResource FontSize.Small}"
                           FontWeight="500"
                           VerticalAlignment="Center"
                           MinWidth="200"
                           Margin="24,0,24,0"/>

                <!-- Logout Button -->
                <Button Grid.Column="3"
                        Content="Logout" 
                        FontSize="{StaticResource FontSize.Normal}"
                        FontWeight="600"
                        Foreground="White"
                        Background="{StaticResource AccentOrangeBrush}"
                        Padding="12,6"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Logout_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Summary & Customer Info -->
            <StackPanel Grid.Column="0">
                <!-- Sales Summary Card -->
                <Border Background="White" CornerRadius="12" Padding="24" Effect="{StaticResource ShadowEffect}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,18">
                            <TextBlock Text="AMOUNT DUE" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="{StaticResource FontSize.Small}"
                                       FontWeight="600"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="67.69" 
                                       FontSize="36" 
                                       FontWeight="700"
                                       Foreground="{StaticResource PrimaryBlueBrush}"/>
                        </StackPanel>

                        <Border Background="{StaticResource BorderGrayBrush}" Height="1" Margin="0,12,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <TextBlock Text="TOTAL ITEMS" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="{StaticResource FontSize.Small}"
                                           FontWeight="600"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="1" 
                                           FontSize="22" 
                                           FontWeight="700"
                                           Foreground="{StaticResource TextDarkBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock Text="Total Savings" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="{StaticResource FontSize.Small}"
                                           FontWeight="600"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="0.00" 
                                           FontSize="22" 
                                           FontWeight="700"
                                           Foreground="{StaticResource TextDarkBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Customer Info Card -->
                <Border Background="White" CornerRadius="12" Padding="24" Effect="{StaticResource ShadowEffect}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="CUSTOMER" 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   FontSize="{StaticResource FontSize.Small}"
                                   FontWeight="600"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="POINTS" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="{StaticResource FontSize.Small}"
                                           FontWeight="500"/>
                                <TextBlock Text="0.0000" 
                                           FontSize="16" 
                                           FontWeight="700"
                                           Foreground="{StaticResource TextDarkBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="LIMIT" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="{StaticResource FontSize.Small}"
                                           FontWeight="500"/>
                                <TextBlock Text="0.00" 
                                           FontSize="16" 
                                           FontWeight="700"
                                           Foreground="{StaticResource TextDarkBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{StaticResource BorderGrayBrush}" Height="1" Margin="0,12,0,12"/>

                        <TextBlock Text="SENIOR/PWD/OFFSETS" 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   FontSize="{StaticResource FontSize.Small}"
                                   FontWeight="600"
                                   Margin="0,8,0,8"/>

                        <ListBox Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderGrayBrush}">
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal" Margin="0,8,10,8">
                                    <TextBlock Text="👤" FontSize="16" Margin="0,0,10,0"/>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="CASHIER" FontWeight="600" Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Text="CAPT. JALEN BRUNSON" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSize.Small}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal" Margin="0,8,10,8">
                                    <TextBlock Text="👤" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="BAGGER" FontWeight="600" Foreground="{StaticResource TextDarkBrush}"/>
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal" Margin="0,8,10,8">
                                    <TextBlock Text="👤" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="SALESMAN" FontWeight="600" Foreground="{StaticResource TextDarkBrush}"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Panel - Products & Barcode -->
            <StackPanel Grid.Column="1" Margin="24,0,0,0">
                <!-- Barcode Scanner -->
                <Border Background="White" CornerRadius="12" Padding="18" Effect="{StaticResource ShadowEffectLight}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="📱" 
                                   FontSize="26"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1"
                                 FontSize="{StaticResource FontSize.Large}"
                                 Padding="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextDarkBrush}"
                                 Text=""/>
                    </Grid>
                </Border>

                <!-- Products Table -->
                <Border Background="White" CornerRadius="12" Effect="{StaticResource ShadowEffect}" Padding="0" Margin="0,0,0,16">
                    <DataGrid AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="White"
                              Margin="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="QTY" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="PRODUCT" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="SALESMAN" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="PROMO" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="SUBTOTAL" Width="120" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Product Info -->
                <Border Background="{StaticResource LightGrayBrush}" 
                        CornerRadius="12" 
                        Padding="18" 
                        BorderThickness="2" 
                        BorderBrush="{StaticResource PrimaryBlueBrush}"
                        Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="PRODUCT" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="{StaticResource FontSize.Small}"
                                       FontWeight="600"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="MARLBORO RED BOX 10 N" 
                                       FontSize="{StaticResource FontSize.Large}"
                                       FontWeight="700"
                                       Foreground="{StaticResource TextDarkBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" 
                                   Text="YOSI GREENCOURT 11:30AM NOW NA" 
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="{StaticResource FontSize.Small}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Function Button Bar -->
        <Border Grid.Row="2" Background="#1A1A2E" Padding="8">
            <UniformGrid Columns="12" Margin="8">
                <!-- F1 - Main Menu -->
                <Button Background="{StaticResource PrimaryBlueBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F1" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Main Menu" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F2 - Item Search -->
                <Button Background="{StaticResource PrimaryBlueBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F2" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Item Search" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F3 - Void Line -->
                <Button Background="{StaticResource PrimaryBlueBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F3" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Void Line" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F4 - Void Transaction -->
                <Button Background="{StaticResource PrimaryBlueBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F4" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Void Transaction" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F5 - Add Customer -->
                <Button Background="{StaticResource AccentGreenBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F5" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Add Customer" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F6 - Add Bagger -->
                <Button Background="{StaticResource AccentGreenBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F6" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Add Bagger" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F7 - Return -->
                <Button Background="{StaticResource AccentGreenBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F7" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Return" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F8 - Lock -->
                <Button Background="{StaticResource AccentGreenBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F8" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Lock" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F9 - CASH -->
                <Button Background="{StaticResource AccentOrangeBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F9" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="CASH" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F10 - CARD -->
                <Button Background="{StaticResource AccentOrangeBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F10" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="CARD" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F11 - EPS -->
                <Button Background="{StaticResource AccentOrangeBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F11" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="EPS" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- F12 - Other -->
                <Button Background="{StaticResource AccentOrangeBrush}" 
                        Style="{StaticResource FunctionButtonStyle}"
                        Margin="3">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="F12" FontSize="11" Foreground="White" TextAlignment="Center" Margin="0,0,0,3" FontWeight="700"/>
                        <TextBlock Text="Other" FontSize="10" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</Window>

<Window x:Class="BarterPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Barter+ - Login" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">
    <Border CornerRadius="15" Background="White" BorderThickness="1" BorderBrush="#E0E0E0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding -->
            <Border Grid.Column="0" Background="{StaticResource PrimaryBlueBrush}" CornerRadius="15,0,0,15">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Barter+" 
                               FontSize="48" 
                               FontWeight="Bold" 
                               Foreground="White"
                               TextAlignment="Center"
                               Margin="0,0,0,30"/>
                    <TextBlock Text="BETTER THAN BARTER SYSTEM FR FR" 
                               FontSize="14" 
                               Foreground="White" 
                               Opacity="0.7"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Right Panel - Login/Register Form -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="50">
                <!-- Close Button -->
                <Button HorizontalAlignment="Right" 
                        Background="Transparent" 
                        BorderThickness="0"
                        FontSize="20"
                        Foreground="#999999"
                        Padding="5"
                        Cursor="Hand"
                        Click="CloseButton_Click">✕</Button>

                <!-- Title -->
                <TextBlock x:Name="FormTitle"
                           Text="Sign In" 
                           FontSize="32" 
                           FontWeight="Bold"
                           Foreground="#2D5AA6"
                           Margin="0,0,0,10"/>

                <TextBlock x:Name="FormSubtitle"
                           Text="Enter your credentials" 
                           FontSize="12"
                           Foreground="#666666"
                           Margin="0,0,0,30"/>

                <!-- Login Form -->
                <StackPanel x:Name="LoginPanel">
                    <!-- Username Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Username" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="LoginUsername"
                                 FontSize="14"
                                 Padding="12,10"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#E0E0E0"
                                 Text=""
                                 Height="40"/>
                    </StackPanel>

                    <!-- Password Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Password" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="LoginPassword"
                                     FontSize="14"
                                     Padding="12,10"
                                     Background="White"
                                     BorderThickness="1"
                                     BorderBrush="#E0E0E0"
                                     Height="40"/>
                    </StackPanel>

                    <!-- Remember Me -->
                    <CheckBox Content="Remember me" 
                              FontSize="12"
                              Foreground="#666666"
                              Margin="0,5,0,0"/>

                    <!-- Sign In Button -->
                    <Button Content="Sign In" 
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="{StaticResource PrimaryBlueBrush}"
                            Padding="0,12"
                            Height="45"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,10,0,0"
                            Click="SignIn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Register Form - Hidden by default -->
                <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                    <!-- Full Name Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Full Name" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="RegisterFullName"
                                 FontSize="14"
                                 Padding="12,10"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#E0E0E0"
                                 Text=""
                                 Height="40"/>
                    </StackPanel>

                    <!-- Email Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Email" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="RegisterEmail"
                                 FontSize="14"
                                 Padding="12,10"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#E0E0E0"
                                 Text=""
                                 Height="40"/>
                    </StackPanel>

                    <!-- Register Username Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Username" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="RegisterUsername"
                                 FontSize="14"
                                 Padding="12,10"
                                 Background="White"
                                 BorderThickness="1"
                                 BorderBrush="#E0E0E0"
                                 Text=""
                                 Height="40"/>
                    </StackPanel>

                    <!-- Register Password Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Password" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="RegisterPassword"
                                     FontSize="14"
                                     Padding="12,10"
                                     Background="White"
                                     BorderThickness="1"
                                     BorderBrush="#E0E0E0"
                                     Height="40"/>
                    </StackPanel>

                    <!-- Confirm Password Field -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Confirm Password" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="RegisterConfirmPassword"
                                     FontSize="14"
                                     Padding="12,10"
                                     Background="White"
                                     BorderThickness="1"
                                     BorderBrush="#E0E0E0"
                                     Height="40"/>
                    </StackPanel>

                    <!-- Terms and Conditions -->
                    <CheckBox Content="I agree to the Terms and Conditions" 
                              FontSize="12"
                              Foreground="#666666"
                              Margin="0,5,0,0"/>

                    <!-- Register Button -->
                    <Button Content="Create Account" 
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="{StaticResource AccentGreenBrush}"
                            Padding="0,12"
                            Height="45"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,10,0,0"
                            Click="Register_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Toggle Link -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock x:Name="ToggleText" 
                               Text="Don't have an account?" 
                               FontSize="12"
                               Foreground="#666666"
                               Margin="0,0,5,0"/>
                    <Button x:Name="ToggleButton"
                            Content="Sign Up" 
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{StaticResource PrimaryBlueBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="2"
                            Click="Toggle_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>

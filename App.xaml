<Application x:Class="BarterPOS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Color Palette - Modern & Refined -->
            <Color x:Key="PrimaryBlue">#1E40AF</Color>
            <Color x:Key="AccentGreen">#059669</Color>
            <Color x:Key="AccentOrange">#EA580C</Color>
            <Color x:Key="DarkGray">#0F172A</Color>
            <Color x:Key="LightGray">#F8FAFC</Color>
            <Color x:Key="BorderGray">#E2E8F0</Color>
            <Color x:Key="TextDark">#1E293B</Color>
            <Color x:Key="TextMuted">#64748B</Color>

            <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
            <SolidColorBrush x:Key="DarkGrayBrush" Color="{StaticResource DarkGray}"/>
            <SolidColorBrush x:Key="LightGrayBrush" Color="{StaticResource LightGray}"/>
            <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
            
            <!-- Effects - Subtle & Modern -->
            <DropShadowEffect x:Key="ShadowEffect" BlurRadius="12" ShadowDepth="3" Opacity="0.08" Color="#000000"/>
            <DropShadowEffect x:Key="ShadowEffectLight" BlurRadius="8" ShadowDepth="2" Opacity="0.05" Color="#000000"/>

            <!-- Font Sizes -->
            <sys:Double x:Key="FontSize.Small">11</sys:Double>
            <sys:Double x:Key="FontSize.Normal">12</sys:Double>
            <sys:Double x:Key="FontSize.Medium">13</sys:Double>
            <sys:Double x:Key="FontSize.Large">15</sys:Double>
            <sys:Double x:Key="FontSize.XLarge">28</sys:Double>
            <sys:Double x:Key="FontSize.Title">32</sys:Double>

            <!-- Button Style - Modern -->
            <Style x:Key="FunctionButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="{StaticResource FontSize.Medium}"/>
                <Setter Property="FontWeight" Value="600"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
